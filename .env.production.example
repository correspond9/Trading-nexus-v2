# =============================================================
# Trading Nexus v2 - Production Environment Variables
# =============================================================
# Copy this file to .env and fill in the actual values

# --- Database ---
POSTGRES_PASSWORD=your_secure_postgres_password_here

# --- Dhan HQ API Credentials (Static IP Mode B) ---
DHAN_CLIENT_ID=your_dhan_client_id_here
DHAN_API_KEY=your_dhan_api_key_here
DHAN_API_SECRET=your_dhan_api_secret_here
DHAN_TOTP_SECRET=your_dhan_totp_secret_here

# --- Application ---
ENVIRONMENT=production
LOG_LEVEL=WARNING
DEBUG=false

# --- API Configuration ---
API_HOST=0.0.0.0
API_PORT=8000

# --- CORS Origins (comma-separated) ---
# Frontend domain requesting access to API
CORS_ORIGINS_RAW=https://app.tradingnexus.pro,http://localhost:3000,http://localhost:5173

# --- Frontend Configuration ---
# Backend API URL that frontend will use
VITE_API_URL=https://api.tradingnexus.pro/api/v2

# --- Market Data Startup Options ---
STARTUP_LOAD_MASTER=false
STARTUP_LOAD_TIER_B=true
STARTUP_START_STREAMS=true
PURGE_TIER_B_EQUITY_ON_STARTUP=false

# --- Optional Features ---
ENABLE_TIER_B_ETF=false
TIER_B_EQUITY_SYMBOLS=RELIANCE,NYKAA
DISABLE_DHAN_WS=false
DISABLE_MARKET_STREAMS=false

# --- Domain Configuration ---
# Traefik will automatically handle these domains:
# - https://api.tradingnexus.pro  → Backend (port 8000)
# - https://app.tradingnexus.pro  → Frontend (port 80)
